<%- include('../partials/header') %>

<style>
  .page-wrap {
    margin-top: 1.5rem;
    max-width: 1100px;
  }

  .page-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
  }

  .page-subtitle {
    margin: 0 0 1rem 0;
    color: var(--text-muted);
  }

  .filter-form {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
  padding: 0.85rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
  max-width: 520px;
  width: 100%;
  box-sizing: border-box;
}

.filter-form input[type="date"] {
  padding: 0.65rem 0.8rem;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: #fff;
  font: inherit;
  margin: 0;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

  .records-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .records-table {
    width: 100%;
    border-collapse: collapse;
  }

  .records-table th,
  .records-table td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }

  .records-table th {
    background: rgba(48, 108, 134, 0.06);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .table-wrap {
    width: 100%;
    overflow-x: auto;
  }

  @media (max-width: 768px) {
    .page-wrap {
      margin-top: 1rem;
    }

    .page-title {
      font-size: 1.25rem;
    }

    .page-subtitle {
      font-size: 0.95rem;
    }

    .filter-form {
    padding: 0.75rem;
    gap: 0.6rem;
    max-width: 100%;
  }

    .filter-form input[type="date"],
    .filter-form .btn {
    width: 100%;
    min-height: 44px;
    box-sizing: border-box;
  }
}


    .records-table th,
    .records-table td {
      padding: 0.7rem 0.8rem;
      font-size: 0.92rem;
    }

    .records-table th {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .filter-form {
    flex-direction: column;
    align-items: stretch;
  }
}

    .page-title {
      font-size: 1.1rem;
    }

    .records-table th,
    .records-table td {
      padding: 0.65rem 0.7rem;
      font-size: 0.88rem;
    }
  }
</style>

<div class="page-wrap">
  <h1 class="page-title">سجلات الحضور</h1>
  <p class="page-subtitle">اختر تاريخًا لعرض جميع سجلات الحضور من ذلك اليوم فقط</p>

  <form method="GET" action="/superadmin/attendance-records" class="filter-form">
    <label for="date" >اختر التاريخ</label>
    <input type="date" name="selectedDate" value="<%= selectedDate || '' %>">
    <button type="submit" class="btn primary">إظهار السجلات</button>
    <a href="/superadmin/attendance-records" class="btn">امسح</a>
  </form>

  <div class="records-card">
    <% if (records && records.length) { %>
      <div class="table-wrap">
        <table class="records-table">
          <thead>
            <tr>
              <th>التاريخ</th>
              <th>الفصل</th>
              <th>إجمالي الطالبات</th>
              <th>الغياب</th>
              <th>الحضور</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td>
                  <%= new Date(r.attendanceDate).toLocaleDateString('ar-KW', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  }) %>
                </td>
                <td><%= r.className %></td>
                <td><%= r.totalStudents %></td>
                <td><%= r.totalAbsent %></td>
                <td><%= r.totalPresent %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        لم يتم العثور على سجلات حضور لهذا التاريخ
      </div>
    <% } %>
  </div>
</div>