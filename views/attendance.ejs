<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/animation.css">

<style>
  
  .classes-wrap {
    margin-top: 1.5rem;
    max-width: 720px;
  }

  .classes-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .classes-title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text);
  }

  .classes-subtitle {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .classes-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .class-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    transition: background 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .class-row:hover {
    box-shadow: var(--shadow);
    border-color: rgba(48, 108, 134, 0.25);
  }

  .class-row__main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }

  .class-row__name {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
    letter-spacing: 0.2px;
  }

  .class-row__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .sub-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0 0.95rem;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--primary);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s, background 0.15s, transform 0.05s ease;
    box-sizing: border-box;
    white-space: nowrap;
  }

  .sub-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: rgba(48, 108, 134, 0.06);
  }

  .sub-btn:active {
    transform: translateY(1px);
  }

  .empty-state {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--text-muted);
    font-size: 1.05rem;
    border: 1px dashed var(--border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
  }

  .submit-area {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 15px;
    flex-wrap: wrap;
  }

  .submit-area input {
    height: 36px;
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
  }
</style>

<div class="classes-wrap">
  <div class="classes-header">
    <div>
      <h1 class="classes-title"><%= className %> الطالبات</h1>
      <p class="classes-subtitle"><%= teacherName %> :المعلمة الحالية</p>
    </div>
  </div>

  <form method="POST" action="/attendance">
    <input type="hidden" name="classID" value="<%= classID %>">
    <input type="hidden" name="currentTeacherID" value="<%= classRow ? classRow.currentTeacherID : '' %>">

    <% if (students && students.length) { %>
      <div class="classes-list">
        <% students.forEach(s => { %>
          <div class="class-row">
            <div class="class-row__main">
              <h2 class="class-row__name" id="<%= s.studentID %>"><%= s.studentName %></h2>
            </div>

            <div class="class-row__actions">
              <input type="hidden" name="<%= s.studentID %>" value="Absent">

              <div class="checkbox-wrapper-44">
                <label class="toggleButton">
                  <input
                    type="checkbox"
                    name="<%= s.studentID %>"
                    value="Present"
                    aria-label="Mark <%= s.studentName %> present"
                    <%= s.status === 'Present' ? 'checked' : '' %>
                  >

                  <div>
                    <svg viewBox="0 0 44 44">
                      <path d="M14,24 L21,31 L39.7428882,11.5937758 C35.2809627,6.53125861 30.0333333,4 24,4 C12.95,4 4,12.95 4,24 C4,35.05 12.95,44 24,44 C35.05,44 44,35.05 44,24 C44,19.3 42.5809627,15.1645919 39.7428882,11.5937758" transform="translate(-2.000000, -2.000000)"></path>
                    </svg>
                  </div>
                </label>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        لم يتم العثور على أي طلاب حتى الآن. أضف طالبًا لبدء تسجيل الحضور.
      </div>
    <% } %>

    <br>

    <div class="submit-area">
      <input type="text" name="currentTeacher" id="currentTeacher" placeholder="اسم المعلمة" required>
      <button type="submit" class="sub-btn">إرسال الحضور</button>
      <p class="classes-subtitle">
        Last updated: <%= date ? new Date(date).toLocaleString() : "No submissions yet" %> by <%= teacherName %>
      </p>
    </div>
  </form>
</div>