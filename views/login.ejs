<link rel="stylesheet" href="/css/pages.css">
<style>
body {
  margin: 0;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #306C86;
}

.login-container {
  background: white;
  padding: 35px;
  border-radius: 10px;
  width: 320px;
  max-width: 90%;
  text-align: center;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}
input {
  width: 100%;
  padding: 8px;
  box-sizing: border-box;
}
.logo-top {
  text-align: center;
  margin-bottom: 15px;
}

.logo-top img {
  height: 90px;
}
button {
  width: 100%;
  background-color: #306C86;
  color: white;
  border: none;
  padding: 10px;
  border-radius: 6px;
  font-size: 15px;
  cursor: pointer;
}

button:hover {
  background-color: #285a70;
}
</style>

<!DOCTYPE html>
<html lang="ar-KW">
<head>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta charset="UTF-8">
  <title>تسجيل الدخول</title>
</head>
<body>
  <div class="login-container">

    <div class="logo-top">
      <img src="/images/logo.png" alt="School Logo">
    </div>
    <h1>تسجيل الدخول</h1>

    <% if (error) { %>
      <p style="color: red;"><%= error %></p>
    <% } %>

    <form action="/login" method="POST">
      <div>
        <label>اسم المستخدم </label>
        <input type="text" name="username" required>
      </div>
      <br>
      <div>
        <label>كلمة المرور </label>
        <input type="password" name="password" required>
      </div>
      <br>
      <button type="submit">سجل</button>
    </form>
  </div>
</body>
</html>