<%- include('../partials/header') %>

<style>
  .dashboard-page {
  padding: 0;
  background: var(--bg);
  }

  .dashboard-header {
    margin-bottom: 24px;
  }

  .dashboard-header h1 {
    margin: 0 0 8px 0;
    color: var(--primary);
    font-size: 2rem;
  }

  .dashboard-header p {
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
  }

  .dashboard-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 20px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .dashboard-card-top h2 {
    margin: 0 0 18px 0;
    color: var(--text);
    font-size: 1.2rem;
  }

  .dashboard-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .stat-box {
    background: rgba(48, 108, 134, 0.04);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-box.wide {
    grid-column: 1 / -1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
  }

  .date-value {
    font-size: 1rem;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .dashboard-page {
      padding: 18px;
    }

    .dashboard-header h1 {
      font-size: 1.5rem;
    }

    .dashboard-header p {
      font-size: 0.95rem;
    }

    .dashboard-grid {
      gap: 16px;
    }

    .dashboard-card {
      padding: 16px;
      border-radius: 14px;
    }

    .dashboard-card-top h2 {
      font-size: 1.05rem;
      margin-bottom: 14px;
    }

    .dashboard-stats {
      gap: 10px;
    }

    .stat-box {
      padding: 12px;
    }

    .stat-label {
      font-size: 0.85rem;
    }

    .stat-value {
      font-size: 1.2rem;
    }

    .date-value {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .dashboard-page {
      padding: 14px;
    }

    .dashboard-header h1 {
      font-size: 1.3rem;
    }

    .dashboard-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<main class="dashboard-page">
  <section class="dashboard-header">
    <h1>لوحة الحضور</h1>
    <p>نظرة عامة على الحضور حسب الصف</p>
  </section>

  <section class="dashboard-grid">
    <% if (cards && cards.length > 0) { %>
      <% cards.forEach(card => { %>
        <div class="dashboard-card">
          <div class="dashboard-card-top">
            <h2><%= card.className %></h2>
          </div>

          <div class="dashboard-stats">
            <div class="stat-box">
              <span class="stat-label">الطالبات</span>
              <span class="stat-value"><%= card.totalStudents || 0 %></span>
            </div>

            <div class="stat-box">
              <span class="stat-label">الغياب</span>
              <span class="stat-value"><%= card.totalAbsences || 0 %></span>
            </div>

            <div class="stat-box">
              <span class="stat-label">الحضور</span>
              <span class="stat-value"><%= card.totalAttendees || 0 %></span>
            </div>

            <div class="stat-box wide">
              <span class="stat-label">آخر تسجيل</span>
              <span class="stat-value date-value">
                <%= card.lastAttendanceDate
                  ? new Date(card.lastAttendanceDate).toLocaleString('ar-KW', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit'
                    })
                  : 'لا يوجد تسجيل حضور بعد' %>
              </span>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p>لم يتم العثور على أي صفوف.</p>
    <% } %>
  </section>
</main>