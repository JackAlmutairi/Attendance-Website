<%- include('../partials/header') %>

<style>
  .owner-wrap {
    max-width: 760px;
    margin: 1.5rem auto;
    direction: rtl;
    text-align: right;
  }

  .owner-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
    margin-bottom: 1rem;
  }

  .owner-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
  }

  .owner-subtitle {
    margin: 0 0 1rem 0;
    color: var(--text-muted);
  }

  .owner-section-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary);
  }

  .owner-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .owner-form input[type="file"],
  .owner-form input[type="password"] {
    padding: 0.7rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    font: inherit;
    background: #fff;
    width: 100%;
    box-sizing: border-box;
  }

  .msg {
    padding: 0.85rem 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .msg.success {
    background: rgba(34, 197, 94, 0.12);
    color: #15803d;
    border: 1px solid rgba(34, 197, 94, 0.25);
  }

  .msg.error {
    background: rgba(239, 68, 68, 0.12);
    color: #b91c1c;
    border: 1px solid rgba(239, 68, 68, 0.25);
  }

  .danger-note {
    color: #b91c1c;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .danger-btn {
    background: #b91c1c;
    color: white;
    border: none;
  }

  .danger-btn:hover {
    background: #991b1b;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 16px;
  }

  .modal-overlay.active {
    display: flex;
  }

  .modal-box {
    width: 100%;
    max-width: 460px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
    padding: 1.25rem;
    direction: rtl;
    text-align: right;
    animation: modalFade 0.18s ease;
  }

  .modal-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.2rem;
    font-weight: 800;
    color: #b91c1c;
  }

  .modal-text {
    margin: 0 0 1rem 0;
    color: #444;
    line-height: 1.8;
  }

  .modal-label {
    display: block;
    margin-bottom: 0.45rem;
    font-weight: 700;
    color: var(--text);
  }

  .modal-input {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    font: inherit;
    box-sizing: border-box;
    margin-bottom: 1rem;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .modal-actions .btn {
    min-width: 120px;
  }

  @keyframes modalFade {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="owner-wrap">

  <div class="owner-card">
    <h1 class="owner-title">لوحة التحكم المتقدمة</h1>
    <p class="owner-subtitle">أدوات خاصة لإدارة بيانات الطالبات وإعادة ضبط النظام.</p>

    <% if (message) { %>
      <div class="msg success"><%= message %></div>
    <% } %>

    <% if (error) { %>
      <div class="msg error"><%= error %></div>
    <% } %>
  </div>

  <div class="owner-card">
    <h2 class="owner-section-title">استيراد ملف الطالبات (Excel)</h2>

    <p class="danger-note">
      تنبيه: عند الاستمرار، سيتم حذف جميع بيانات الطالبات الحالية واستبدالها بالملف الجديد.
    </p>

    <form
      id="importStudentsForm"
      class="owner-form"
      action="/superadmin/import-students"
      method="POST"
      enctype="multipart/form-data"
    >
      <input
        type="file"
        id="studentsFile"
        name="studentsFile"
        accept=".xlsx,.xls"
        required
      >

      <input
        type="hidden"
        name="ownerPassword"
        id="ownerPasswordInput"
      >

      <button
        type="button"
        class="btn primary"
        onclick="openImportModal()"
      >
        استيراد الطالبات
      </button>
    </form>
  </div>

  <div class="owner-card">
    <h2 class="owner-section-title">إعادة ضبط بيانات الطالبات</h2>
    <p class="danger-note">سيتم حذف جميع بيانات الطالبات من قاعدة البيانات.</p>

    <form
      class="owner-form"
      action="/superadmin/reset-students"
      method="POST"
      onsubmit="return confirm('هل أنت متأكد من حذف جميع بيانات الطالبات؟');"
    >
      <input
        type="password"
        name="password"
        placeholder="أدخل كلمة مرور الإدارة"
        required
      >

      <button type="submit" class="btn">حذف بيانات الطالبات</button>
    </form>
  </div>

  <div class="owner-card">
    <h2 class="owner-section-title">إعادة ضبط سجلات الحضور</h2>
    <p class="danger-note">سيتم حذف جميع سجلات الحضور من النظام.</p>

    <form
      class="owner-form"
      action="/superadmin/reset-attendance"
      method="POST"
      onsubmit="return confirm('هل أنت متأكد من حذف جميع سجلات الحضور؟');"
    >
      <input
        type="password"
        name="password"
        placeholder="أدخل كلمة مرور الإدارة"
        required
      >

      <button type="submit" class="btn">حذف سجلات الحضور</button>
    </form>
  </div>

</div>

<div id="importModal" class="modal-overlay">
  <div class="modal-box">
    <h3 class="modal-title">تأكيد استيراد الطالبات</h3>

    <p class="modal-text">
      المتابعة ستؤدي إلى حذف جميع بيانات الطالبات الحالية واستبدالها بالملف الجديد.
      هل أنت متأكد من المتابعة؟
    </p>

    <label class="modal-label" for="modalOwnerPassword">
      كلمة مرور الإدارة
    </label>

    <input
      type="password"
      id="modalOwnerPassword"
      class="modal-input"
      placeholder="أدخل كلمة مرور الإدارة"
    >

    <div class="modal-actions">
      <button type="button" class="btn danger-btn" onclick="submitImportForm()">
        تأكيد الاستيراد
      </button>

      <button type="button" class="btn" onclick="closeImportModal()">
        إلغاء
      </button>
    </div>
  </div>
</div>

<script>
  function openImportModal() {
    const fileInput = document.getElementById('studentsFile');

    if (!fileInput.files || fileInput.files.length === 0) {
      alert('يرجى اختيار ملف Excel أولاً');
      return;
    }

    document.getElementById('importModal').classList.add('active');
    document.getElementById('modalOwnerPassword').value = '';
    document.getElementById('modalOwnerPassword').focus();
  }

  function closeImportModal() {
    document.getElementById('importModal').classList.remove('active');
  }

  function submitImportForm() {
    const password = document.getElementById('modalOwnerPassword').value.trim();

    if (!password) {
      alert('يرجى إدخال كلمة مرور الإدارة');
      return;
    }

    document.getElementById('ownerPasswordInput').value = password;
    document.getElementById('importStudentsForm').submit();
  }

  document.getElementById('importModal').addEventListener('click', function (e) {
    if (e.target.id === 'importModal') {
      closeImportModal();
    }
  });
</script>