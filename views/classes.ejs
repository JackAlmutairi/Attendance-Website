<%- include('../partials/header') %>

<style>
  .classes-header__actions .btn {
    min-width: 140px;
    justify-content: center;
    font-weight: 700;
    border-radius: 12px;
    box-shadow: 0 6px 14px rgba(48, 108, 134, 0.14);
  }

  .class-row {
    border: 1px solid #d8e2e9;
    box-shadow: 0 4px 14px rgba(15, 43, 70, 0.04);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .class-row:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 22px rgba(15, 43, 70, 0.08);
    border-color: #c8d6df;
  }

  .class-row__name {
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .class-row__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.32rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid rgba(48, 108, 134, 0.14);
    background: rgba(48, 108, 134, 0.08);
    color: var(--primary);
    white-space: nowrap;
  }

  .pill.secondary {
    background: #f2f5f7;
    border-color: #d7e0e6;
    color: #70808d;
  }

  .class-row__actions .btn {
    min-width: 108px;
    justify-content: center;
    border-radius: 12px;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .pill {
      font-size: 0.72rem;
    }

    .btn {
      min-height: 44px;
      font-size: 0.92rem;
      padding: 0 1rem;
    }

    .classes-header__actions .btn {
      min-width: 126px;
    }

    .class-row__actions .btn {
      min-width: 96px;
    }
  }

  @media (max-width: 480px) {
    .btn {
      width: 100%;
    }

    .classes-header__actions {
      width: 100%;
    }
  }
</style>


<div class="classes-wrap">
  <div class="classes-header">
    <div>
      <h1 class="classes-title">الفصول الدراسية</h1>
      <p class="classes-subtitle">اختر فصلاً دراسياً لتسجيل الحضور.</p>
    </div>

    <div class="classes-header__actions">
      <a href="/teacher-attendance" class="btn primary">
        حضور المعلمات
      </a>
    </div>
  </div>

  <% if (classes && classes.length) { %>
    <div class="classes-list">
      <% classes.forEach(c => { %>
        <div class="class-row">
          <div class="class-row__main">
            <h2 class="class-row__name"><%= c.className %></h2>

            <div class="class-row__meta">
              <% if (c.teacherName) { %>
                <span class="pill">👩‍🏫 <%= c.teacherName %></span>
              <% } else { %>
                <span class="pill secondary">لم يتم تعيين أي معلمة</span>
              <% } %>
            </div>
          </div>

          <div class="class-row__actions">
            <a class="btn primary" href="/attendance?classID=<%= c.classID %>">تسجيل الحضور</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state">
      لم يتم العثور على أي صفوف حتى الآن. أضف صفًا لبدء تسجيل الحضور.
    </div>
  <% } %>
</div>