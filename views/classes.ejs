<%- include('../partials/header') %>

<style>
  .class-row__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(48, 108, 134, 0.10);
    color: var(--primary);
    white-space: nowrap;
  }

  .pill.secondary {
    background: rgba(72, 101, 129, 0.08);
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .pill {
      font-size: 0.72rem;
    }

    .btn {
      min-height: 44px;
      font-size: 0.92rem;
      padding: 0 1rem;
    }
  }

  @media (max-width: 480px) {
    .btn {
      width: 100%;
    }
  }
</style>

<div class="classes-wrap">
  <div class="classes-header">
    <div>
      <h1 class="classes-title">الفصول الدراسية</h1>
      <p class="classes-subtitle">اختر فصلاً دراسياً لتسجيل الحضور.</p>
    </div>
  </div>

  <% if (classes && classes.length) { %>
    <div class="classes-list">
      <% classes.forEach(c => { %>
        <div class="class-row">
          <div class="class-row__main">
            <h2 class="class-row__name"><%= c.className %></h2>

            <div class="class-row__meta">
              <% if (c.teacherName) { %>
                <span class="pill">👩‍🏫 <%= c.teacherName %></span>
              <% } else { %>
                <span class="pill secondary">لم يتم تعيين أي معلمة</span>
              <% } %>
            </div>
          </div>

          <div class="class-row__actions">
            <a class="btn primary" href="/attendance?classID=<%= c.classID %>">تسجيل الحضور</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state">
      لم يتم العثور على أي صفوف حتى الآن. أضف صفًا لبدء تسجيل الحضور.
    </div>
  <% } %>
</div>