 <!DOCTYPE html>
<html lang="ar-KW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>مدرسة أم سنان الإسلامية – بنات</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
  <style>
:root{
  --bg:#F5F7FA;
  --surface:#FFFFFF;
  --border:#D9E2EC;
  --text:#102A43;
  --text-muted:#486581;
  --primary:#306C86;
  --primary-hover:#3f7f9c;
  --accent:#4f8faa;
  --accent-hover:#6aa4bd;
  --radius:12px;
  --shadow:0 10px 28px rgba(0,0,0,.08);
  --shadow-sm:0 6px 16px rgba(0,0,0,.06);
}

*{
  box-sizing:border-box;
}

html,
body{
  height:100%;
}

body{
  font-family:'DM Sans', system-ui, sans-serif;
  background:var(--bg);
  color:var(--text);
  max-width:1080px;
  margin:0 auto;
  padding:0 1.25rem 3rem;
  line-height:1.6;
  font-size:1.05rem;
  overflow-x:hidden;
}

nav{
  width:100vw;
  margin-left:calc(50% - 50vw);
  margin-right:calc(50% - 50vw);
  margin-bottom:2rem;
  padding:1rem 0;
  background:var(--primary);
  border-bottom:1px solid var(--border);
}

.nav-inner{
  display:flex;
  align-items:center;
  justify-content:space-between;
  position:relative;
  gap:12px;
  max-width:1080px;
  margin:0 auto;
  padding:0 1rem;
  flex-wrap:wrap;
}

nav a{
  text-decoration:none;
  border-radius:10px;
}

nav a:focus-visible{
  outline:2px solid rgba(255,255,255,.35);
  outline-offset:2px;
}

nav a.nav-brand{
  position:relative;
  z-index:1;
  display:inline-flex;
  align-items:center;
  gap:.9rem;
  color:var(--text);
  font-weight:800;
  font-size:1.25rem;
  padding:.5rem .75rem;
}

.nav-home-box{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:3.25rem;
  height:3.25rem;
  border-radius:var(--radius);
  border:1px solid var(--border);
  background:var(--surface);
  box-shadow:var(--shadow-sm);
}

.nav-home-box svg{
  width:1.8rem;
  height:1.8rem;
  fill:currentColor;
}

.nav-center-logo{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  padding-top:8px;
  padding-bottom:5px;
}

.nav-center-logo img{
  height:100px;
}

.nav-logout{
  margin-left:auto;
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
}

.logout-btn{
  background:var(--primary);
  color:white;
  padding:10px 14px;
  border-radius:8px;
  text-decoration:none;
  font-weight:500;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:44px;
  text-align:center;
  border:1px solid rgba(255,255,255,.18);
}

.logout-btn:hover{
  background:#25566b;
}

h1{
  font-size:2rem;
  font-weight:800;
  margin:0 0 .6rem;
}

.subtitle{
  color:var(--text-muted);
  margin:0 0 1.5rem;
  font-size:1.1rem;
}

.action-grid,
.home-cards{
  list-style:none;
  padding:0;
  margin:0;
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:1.25rem;
}

.action-card,
.home-card,
ul.links a{
  display:block;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  text-decoration:none;
  box-shadow:var(--shadow-sm);
  transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease;
}

.action-card:hover,
.home-card:hover,
ul.links a:hover{
  transform:translateY(-2px);
  border-color:rgba(31,111,235,.35);
  box-shadow:var(--shadow);
}

.action-card:focus-visible,
.home-card:focus-visible,
ul.links a:focus-visible{
  outline:2px solid rgba(31,111,235,.35);
  outline-offset:2px;
}

.action-card{
  padding:1.1rem 1.25rem;
}

.action-card__title{
  display:block;
  font-size:1.1rem;
  font-weight:800;
  color:var(--primary);
  margin:0 0 .25rem;
}

.action-card__desc{
  margin:0;
  color:var(--text-muted);
  font-size:.95rem;
}

.home-card{
  display:flex;
  align-items:center;
  gap:1rem;
  padding:1.1rem 1.25rem;
  color:var(--primary);
  font-weight:800;
}

.home-card__icon{
  width:2.25rem;
  height:2.25rem;
  display:flex;
  align-items:center;
  justify-content:center;
}

.home-card__icon svg{
  width:100%;
  height:100%;
}

.home-card__label{
  flex:1;
}

ul.links{
  list-style:none;
  padding:0;
  margin:0;
  display:grid;
  gap:.75rem;
}

ul.links a{
  padding:1rem 1.25rem;
  color:var(--primary);
  font-weight:700;
}

.toolbar{
  display:flex;
  flex-wrap:wrap;
  gap:.75rem;
  margin-bottom:1.5rem;
}

.toolbar a{
  padding:.55rem 1rem;
  background:var(--surface);
  color:var(--primary);
  border:1px solid var(--border);
  border-radius:999px;
  font-weight:800;
  text-decoration:none;
}

.toolbar a:hover{
  border-color:rgba(31,111,235,.35);
  background:rgba(11,61,145,.05);
}

.toolbar a.primary{
  background:var(--primary);
  border-color:var(--primary);
  color:white;
}

.toolbar a.primary:hover{
  background:var(--primary-hover);
}

form:not(.filter-form){
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:16px;
  padding:1.5rem;
  box-shadow:var(--shadow-sm);
  max-width:630px;
  width:100%;
}

form:not(.filter-form) label{
  display:block;
  margin:0 0 1.1rem;
  font-weight:800;
  color:var(--text);
}

form:not(.filter-form) input,
form:not(.filter-form) select,
form:not(.filter-form) textarea{
  width:100%;
  margin-top:.45rem;
  padding:.7rem .9rem;
  border:1px solid var(--border);
  border-radius:12px;
  font:inherit;
  background:white;
  color:var(--text);
}

form:not(.filter-form) input:focus,
form:not(.filter-form) select:focus,
form:not(.filter-form) textarea:focus{
  outline:none;
  border-color:rgba(31,111,235,.55);
  box-shadow:0 0 0 4px rgba(31,111,235,.15);
}

form:not(.filter-form) button{
  padding:.75rem 1.25rem;
  background:var(--primary);
  color:white;
  border:none;
  border-radius:12px;
  font:inherit;
  font-weight:900;
  cursor:pointer;
}

form:not(.filter-form) button:hover{
  background:var(--primary-hover);
}

form:not(.filter-form) button:focus-visible{
  outline:2px solid rgba(31,111,235,.35);
  outline-offset:2px;
}

.back-link{
  display:inline-block;
  margin-top:1.25rem;
  color:var(--text-muted);
  text-decoration:none;
  font-weight:700;
}

.back-link:hover{
  color:var(--primary);
}

.empty-state{
  background:var(--surface);
  border:1px dashed rgba(16,42,67,.25);
  border-radius:16px;
  padding:2rem;
  text-align:center;
  color:var(--text-muted);
  box-shadow:var(--shadow-sm);
}

.data-list{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:16px;
  overflow:hidden;
  box-shadow:var(--shadow-sm);
}

.data-list ul{
  list-style:none;
  margin:0;
  padding:0;
}

.data-list li{
  padding:1rem 1.25rem;
  border-bottom:1px solid var(--border);
}

.data-list li:last-child{
  border-bottom:none;
}

table{
  width:100%;
  border-collapse:collapse;
  background:var(--surface);
}

th,
td{
  padding:.9rem 1rem;
  border-bottom:1px solid var(--border);
  text-align:right;
}

th{
  color:var(--text);
  font-weight:900;
  background:rgba(11,61,145,.04);
}

tr:hover td{
  background:rgba(11,61,145,.03);
}

@media (max-width: 768px){
  body{
    padding:0 .9rem 2rem;
    font-size:1rem;
  }

  .nav-center-logo{
    position:static;
    left:auto;
    transform:none;
    order:-1;
    width:100%;
    display:flex;
    justify-content:center;
    padding-top:0;
    padding-bottom:.25rem;
  }

  .nav-center-logo img{
    height:70px;
  }

  .nav-logout{
    margin-left:0;
    width:100%;
    justify-content:center;
  }

  .logout-btn{
    font-size:.95rem;
    padding:10px 12px;
  }

  nav a.nav-brand{
    font-size:1rem;
  }

  .nav-home-box{
    width:2.8rem;
    height:2.8rem;
  }

  .nav-home-box svg{
    width:1.45rem;
    height:1.45rem;
  }
}

@media (max-width:640px){
  .action-grid,
  .home-cards{
    grid-template-columns:1fr;
  }
}
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">

    <a href="/" class="nav-brand" title="Home" aria-label="Home">
      <span class="nav-home-box">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
        </svg>
      </span>
    </a>

    <div class="nav-center-logo">
      <img src="/images/logo.png" alt="School Logo">
    </div>

    <div class="nav-logout">
      <a href="/logout" class="logout-btn">
        تسجيل الخروج
      </a>

      <% if (session && session.role === 'superadmin') { %>
        <a href="/superadmin/dashboard" class="logout-btn">
          لوحة الحضور
        </a>

        <a href="/superadmin/attendance-records" class="logout-btn">
          عرض الحضور
        </a>
      <% } %>
    </div>

  </div>
</nav>